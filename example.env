# Polymarket US credentials (required for live mode, optional for dry-run).
# Generate these at: https://polymarket.us/developer
POLYMARKET_KEY_ID=your-key-id
POLYMARKET_SECRET_KEY=your-secret-key

# Optional endpoint overrides (defaults are already set in config files).
POLYMARKET_PUBLIC_URL=https://gateway.polymarket.us
POLYMARKET_PRIVATE_URL=https://api.polymarket.us
POLYMARKET_MARKETS_WS_URL=wss://api.polymarket.us/v1/ws/markets
POLYMARKET_PRIVATE_WS_URL=wss://api.polymarket.us/v1/ws/private

# Optional transport toggles.
POLYMARKET_USE_WEBSOCKET=true
POLYMARKET_USE_REST_FALLBACK=true

# Optional cache overrides.
CACHE_ENABLED=true
CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=pmarb
CACHE_CONNECT_TIMEOUT_SECONDS=1.0
CACHE_OP_TIMEOUT_SECONDS=0.5
CACHE_MARKETS_TTL_SECONDS=900
CACHE_MATCHES_TTL_SECONDS=3600
